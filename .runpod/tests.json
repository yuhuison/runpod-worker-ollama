{
  "tests": [
    {
      "name": "execute_a_prompt",
      "input": {
        "prompt": "Say: Hello World!"
      },
      "timeout": 120000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "LLAMA_ARG_MODEL",
