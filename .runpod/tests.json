      },
      {
        "key": "LLAMA_ARG_CTX_SIZE",
        "value": "4096"
      },
      {
        "key": "LLAMA_ARG_N_GPU_LAYERS",
        "value": "99"
      }
    ],
    "allowedCudaVersions": [
      "12.4"
    ]
  }
}
